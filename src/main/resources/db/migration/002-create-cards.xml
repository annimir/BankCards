<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-cards" author="bankcards">
        <createTable tableName="cards">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="card_number_encrypted" type="VARCHAR(512)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="card_number_masked" type="VARCHAR(19)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_cards_users"
                             references="users(id)"/>
            </column>
            <column name="expiry_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="balance" type="DECIMAL(15,2)" defaultValueNumeric="0.00">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="cards" indexName="idx_cards_owner_id">
            <column name="owner_id"/>
        </createIndex>

        <createIndex tableName="cards" indexName="idx_cards_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>